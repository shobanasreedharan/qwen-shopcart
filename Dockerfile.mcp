FROM python:3.11

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# IMPORTANT: ensure Python sees /app as root module base
ENV PYTHONPATH=/app

CMD ["python", "-m", "uvicorn", "backend.core.mcp_bootstrap:app", "--host", "0.0.0.0", "--port", "8080", "--proxy-headers", "--forwarded-allow-ips", "*"]